# DiscoSights Environment Variables
# Copy this file to .env and fill in your credentials

# Supabase (required)
# Get from: https://supabase.com/dashboard/project/[id]/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Census API (optional — keyless works at low rate)
# Register at: https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=your-census-api-key

# Railway PostgreSQL (only needed for direct DB access)
# Get from: Railway dashboard -> your project -> Variables
DATABASE_URL=postgresql://user:pass@host:port/dbname

# Admin key for cache invalidation endpoint
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_KEY=your-random-secret-here

# API server settings
PORT=8000
ENVIRONMENT=development
