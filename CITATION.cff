    given-names: Greg
    alias: gregjlake
    orcid: https://orcid.org/0009-0004-4071-4099
repository-code: https://github.com/gregjlake/discovery-pipeline
url: https://discovery-surface-spark.lovable.app
license: MIT
date-released: "2026-04-01"
keywords:
  - gravity model
  - socioeconomic similarity
  - county data
  - spatial analysis
  - policy research
  - United States
